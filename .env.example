# Example .env file for the Walk-Forward HRP Portfolio Engine
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual token.
# .env is listed in .gitignore and will NEVER be committed to version control.
#
# How to generate a GitHub Personal Access Token:
#   GitHub → Settings → Developer settings → Personal access tokens
#   → Fine-grained tokens → Generate new token
#   Required scope: "Contents" (read & write) on the target repository.
# ─────────────────────────────────────────────────────────────────────────────

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
